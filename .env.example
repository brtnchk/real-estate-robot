# Copy to .env and adjust if needed. docker-compose reads .env automatically.

POSTGRES_USER=olx
POSTGRES_PASSWORD=olx
POSTGRES_DB=olx
POSTGRES_PORT=5432

RABBITMQ_USER=olx
RABBITMQ_PASSWORD=olx
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Used by the Go app
DATABASE_URL=postgres://olx:olx@localhost:5432/olx?sslmode=disable
AMQP_URL=amqp://olx:olx@localhost:5672/
