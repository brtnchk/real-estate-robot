# Copy to .env and adjust. docker-compose reads this automatically.

# --- Infrastructure --------------------------------------------------------
POSTGRES_USER=olx
POSTGRES_PASSWORD=olx
POSTGRES_DB=olx
POSTGRES_PORT=5432

RABBITMQ_USER=olx
RABBITMQ_PASSWORD=olx
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# --- Used by Go workers running LOCALLY (outside Docker) ------------------
# When running inside Docker, services connect via container hostnames
# (postgres, rabbitmq) — these values are overridden in docker-compose.yml.
DATABASE_URL=postgres://olx:olx@localhost:5432/olx?sslmode=disable
AMQP_URL=amqp://olx:olx@localhost:5672/

# --- Scheduler config (which cities / categories to crawl) ----------------
SCHEDULER_CITIES=kiev,bucha,irpen,gostomel
SCHEDULER_CATEGORIES=prodazha-kvartir,prodazha-domov,arenda-kvartir
SCHEDULER_INTERVAL=30m

# --- Optional tuning -------------------------------------------------------
DISCOVERY_MAX_PAGE=5
FETCHER_RPS=2
FETCHER_MIN_REFETCH=30m
ENRICHER_RPS=1
ENRICHER_FRESHNESS=6h
API_PORT=8080
